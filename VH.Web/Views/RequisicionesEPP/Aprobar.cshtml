@model VH.Services.DTOs.RequisicionEPPResponseDto
@{
    ViewData["Title"] = $"Aprobar Requisición {Model.NumeroRequisicion}";
}

<div class="container-fluid px-3 px-md-4">

    <!-- Encabezado -->
    <div class="d-flex align-items-center mb-3 mb-md-4">
        <a asp-action="Index" class="btn btn-outline-secondary me-3">
            <i class="bi bi-arrow-left"></i>
        </a>
        <div class="flex-grow-1 min-w-0">
            <h2 class="mb-0 fw-bold text-dark fs-5 fs-md-2">
                <i class="bi bi-clipboard-check text-warning me-2"></i>Aprobar Requisición
            </h2>
            <p class="text-muted mb-0 small">@Model.NumeroRequisicion</p>
        </div>
        <span class="badge bg-warning ms-2 fs-6 px-3 py-2">Pendiente</span>
    </div>

    <div class="row g-3 g-md-4">

        <!-- Info + Materiales -->
        <div class="col-12 col-lg-8">

            <!-- Info general -->
            <div class="card shadow-sm border-0 mb-3 mb-md-4">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0 fs-6 fs-md-5"><i class="bi bi-info-circle me-2"></i>Datos de la Requisición</h5>
                </div>
                <div class="card-body p-3 p-md-4">
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="text-muted small text-uppercase fw-semibold d-block">N° Requisición</label>
                            <span class="fw-bold text-primary">@Model.NumeroRequisicion</span>
                        </div>
                        <div class="col-6">
                            <label class="text-muted small text-uppercase fw-semibold d-block">Fecha Solicitud</label>
                            <span class="small">@Model.FechaSolicitud.ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="text-muted small text-uppercase fw-semibold d-block">Solicitante</label>
                            <span>@Model.NombreUsuarioSolicita</span>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="text-muted small text-uppercase fw-semibold d-block">Empleado Receptor</label>
                            <span class="fw-semibold">@Model.NombreEmpleadoRecibe</span>
                            <small class="text-muted d-block">@Model.NumeroNominaEmpleado</small>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="text-muted small text-uppercase fw-semibold d-block">Almacén</label>
                            <span>@Model.NombreAlmacen</span>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.Justificacion))
                        {
                            <div class="col-12">
                                <label class="text-muted small text-uppercase fw-semibold d-block">Justificación</label>
                                <p class="mb-0 bg-light rounded p-2 small">@Model.Justificacion</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Materiales -->
            <div class="card shadow-sm border-0 mb-3 mb-md-4">
                <div class="card-header bg-success text-white py-3">
                    <h5 class="mb-0 fs-6 fs-md-5"><i class="bi bi-box-seam me-2"></i>Materiales Solicitados</h5>
                </div>

                <!-- Móvil: cards -->
                <div class="d-md-none p-3">
                    @foreach (var detalle in Model.Detalles)
                    {
                        <div class="border rounded p-3 mb-2 bg-light">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="fw-semibold">@detalle.NombreMaterial</span>
                                    <small class="text-muted d-block">@detalle.UnidadMedida</small>
                                </div>
                                <div class="text-end">
                                    <span class="badge bg-primary fs-6">@detalle.CantidadSolicitada</span>
                                    @if (!string.IsNullOrEmpty(detalle.TallaSolicitada))
                                    {
                                        <br>
                                
                                        <span class="badge bg-secondary mt-1">@detalle.TallaSolicitada</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                    <div class="d-flex justify-content-between fw-semibold pt-2 border-top mt-1">
                        <span>Total: @Model.TotalMateriales mat.</span>
                        <span>@Model.TotalCantidadSolicitada uds.</span>
                    </div>
                </div>

                <!-- Escritorio: tabla -->
                <div class="d-none d-md-block table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Material</th>
                                <th class="text-center">Cantidad</th>
                                <th class="text-center">Talla</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var detalle in Model.Detalles)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <strong>@detalle.NombreMaterial</strong>
                                        <br><small class="text-muted">@detalle.UnidadMedida</small>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-primary fs-6">@detalle.CantidadSolicitada</span>
                                    </td>
                                    <td class="text-center">
                                        @(string.IsNullOrEmpty(detalle.TallaSolicitada) ? "-" : detalle.TallaSolicitada)
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <th class="ps-4">Total: @Model.TotalMateriales material(es)</th>
                                <th class="text-center">@Model.TotalCantidadSolicitada</th>
                                <th></th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>

            <!-- Formulario decisión en móvil -->
            <div class="d-md-none">
                <div class="card shadow-sm border-0 mb-3">
                    <div class="card-header bg-dark text-white py-3">
                        <h5 class="mb-0 fs-6"><i class="bi bi-clipboard-check me-2"></i>Decisión</h5>
                    </div>
                    <div class="card-body p-3">
                        <form asp-action="Aprobar" asp-route-id="@Model.IdRequisicion" method="post" class="mb-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="Aprobada" value="true" />
                            <input type="hidden" name="MotivoRechazo" value="" />
                            <button type="submit" class="btn btn-success w-100 btn-lg fw-semibold"
                                    onclick="return confirm('¿Está seguro de APROBAR esta requisición?');">
                                <i class="bi bi-check-lg me-2"></i>Aprobar Requisición
                            </button>
                        </form>

                        <hr>

                        <form asp-action="Aprobar" asp-route-id="@Model.IdRequisicion" method="post" id="formRechazoMobile">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="Aprobada" value="false" />
                            <div class="mb-3">
                                <label class="form-label fw-semibold text-danger">
                                    <i class="bi bi-x-circle me-1"></i>Motivo de Rechazo <span class="text-danger">*</span>
                                </label>
                                <textarea name="MotivoRechazo" class="form-control" rows="3"
                                          placeholder="Indique el motivo del rechazo..."></textarea>
                                <small class="text-muted">Obligatorio si rechaza</small>
                            </div>
                            <button type="submit" class="btn btn-danger w-100 btn-lg">
                                <i class="bi bi-x-lg me-2"></i>Rechazar Requisición
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Panel decisión escritorio -->
        <div class="col-lg-4 d-none d-md-block">
            <div class="card shadow-sm border-0 mb-4" style="position: sticky; top: 1rem;">
                <div class="card-header bg-dark text-white py-3">
                    <h5 class="mb-0"><i class="bi bi-clipboard-check me-2"></i>Decisión</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Aprobar" asp-route-id="@Model.IdRequisicion" method="post" class="mb-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="Aprobada" value="true" />
                        <input type="hidden" name="MotivoRechazo" value="" />
                        <div class="d-grid">
                            <button type="submit" class="btn btn-success btn-lg"
                                    onclick="return confirm('¿Está seguro de APROBAR esta requisición?');">
                                <i class="bi bi-check-lg me-2"></i>Aprobar Requisición
                            </button>
                        </div>
                    </form>

                    <hr class="my-4">

                    <form asp-action="Aprobar" asp-route-id="@Model.IdRequisicion" method="post" id="formRechazo">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="Aprobada" value="false" />
                        <div class="mb-3">
                            <label class="form-label fw-semibold text-danger">
                                <i class="bi bi-x-circle me-1"></i>Motivo de Rechazo
                            </label>
                            <textarea name="MotivoRechazo" id="MotivoRechazo" class="form-control" rows="3"
                                      placeholder="Indique el motivo del rechazo..."></textarea>
                            <small class="text-muted">Obligatorio si rechaza la requisición</small>
                        </div>
                        <div class="d-grid">
                            <button type="submit" class="btn btn-danger" id="btnRechazar">
                                <i class="bi bi-x-lg me-2"></i>Rechazar Requisición
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card shadow-sm border-0 bg-light">
                <div class="card-body">
                    <h6 class="fw-bold"><i class="bi bi-lightbulb text-warning me-2"></i>Información</h6>
                    <ul class="small text-muted mb-0">
                        <li>Al <strong class="text-success">aprobar</strong>, pasará a estado "Aprobada" y podrá ser entregada.</li>
                        <li>Al <strong class="text-danger">rechazar</strong>, debe indicar un motivo.</li>
                        <li>Esta acción no se puede deshacer.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    @@media (max-width: 767.98px) {
        .btn {
            min-height: 48px;
        }

        .form-control {
            min-height: 48px;
        }
    }
</style>

@section Scripts {
    <script>
        // Validación rechazo escritorio
        const formRechazo = document.getElementById('formRechazo');
        if (formRechazo) {
            formRechazo.addEventListener('submit', function(e) {
                const motivo = document.getElementById('MotivoRechazo').value.trim();
                if (motivo === '') {
                    e.preventDefault();
                    alert('Debe indicar el motivo del rechazo.');
                    document.getElementById('MotivoRechazo').focus();
                    return false;
                }
                if (!confirm('¿Está seguro de RECHAZAR esta requisición?')) {
                    e.preventDefault();
                    return false;
                }
            });
        }

        // Validación rechazo móvil
        const formRechazoMobile = document.getElementById('formRechazoMobile');
        if (formRechazoMobile) {
            formRechazoMobile.addEventListener('submit', function(e) {
                const motivo = this.querySelector('textarea[name="MotivoRechazo"]').value.trim();
                if (motivo === '') {
                    e.preventDefault();
                    alert('Debe indicar el motivo del rechazo.');
                    return false;
                }
                if (!confirm('¿Está seguro de RECHAZAR esta requisición?')) {
                    e.preventDefault();
                    return false;
                }
            });
        }
    </script>
}

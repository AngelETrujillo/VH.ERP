@model IEnumerable<VH.Services.DTOs.RequisicionEPPResponseDto>
@{
    ViewData["Title"] = "Requisiciones EPP";
    var esSuperAdmin = User.IsInRole("SuperAdmin");
    var esAdmin = User.IsInRole("Administrador");
    var puedeCrear = PermisoHelper.PuedeCrear(Context.Session, "REQUISICIONES_EPP", esSuperAdmin);
    var puedeEditar = PermisoHelper.PuedeEditar(Context.Session, "REQUISICIONES_EPP", esSuperAdmin);
}

<div class="container-fluid px-3 px-md-4">

    <!-- Encabezado -->
    <div class="d-flex justify-content-between align-items-center mb-3 mb-md-4">
        <div>
            <h2 class="mb-0 fw-bold text-dark fs-4 fs-md-2">
                <i class="bi bi-file-earmark-text text-primary me-2"></i>Requisiciones EPP
            </h2>
            <p class="text-muted mb-0 small d-none d-md-block">Gestión de solicitudes de equipos de protección personal</p>
        </div>
        @if (puedeCrear)
        {
            <a asp-action="Create" class="btn btn-primary shadow-sm">
                <i class="bi bi-plus-lg me-1 me-md-2"></i>
                <span class="d-none d-sm-inline">Nueva </span>Requisición
            </a>
        }
    </div>

    <!-- Alertas -->
    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-2"></i>@TempData["Mensaje"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Filtros con scroll horizontal en móvil -->
    <div class="mb-3 mb-md-4">
        <div class="d-flex gap-2 overflow-auto pb-1 filtros-scroll">
            <a asp-action="Index"
               class="btn @(ViewBag.FiltroActual == null ? "btn-primary" : "btn-outline-primary") btn-sm text-nowrap flex-shrink-0">
                <i class="bi bi-list-ul me-1"></i>Todas
            </a>
            <a asp-action="Index" asp-route-filtro="mis"
               class="btn @(ViewBag.FiltroActual == "mis" ? "btn-primary" : "btn-outline-primary") btn-sm text-nowrap flex-shrink-0">
                <i class="bi bi-person me-1"></i>Mis Requisiciones
            </a>
            @if (esSuperAdmin || esAdmin || puedeEditar)
            {
                <a asp-action="Index" asp-route-filtro="pendientes-aprobacion"
                   class="btn @(ViewBag.FiltroActual == "pendientes-aprobacion" ? "btn-warning" : "btn-outline-warning") btn-sm text-nowrap flex-shrink-0">
                    <i class="bi bi-clock me-1"></i>Pend. Aprobación
                </a>
                <a asp-action="Index" asp-route-filtro="pendientes-entrega"
                   class="btn @(ViewBag.FiltroActual == "pendientes-entrega" ? "btn-info" : "btn-outline-info") btn-sm text-nowrap flex-shrink-0">
                    <i class="bi bi-box-arrow-right me-1"></i>Pend. Entrega
                </a>
            }
        </div>
    </div>

    @if (ViewBag.ErrorMessage != null)
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-2"></i>@ViewBag.ErrorMessage
        </div>
    }

    <!-- ===================== VISTA MÓVIL: Cards ===================== -->
    <div class="d-md-none">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="card shadow-sm border-0 mb-3 requisicion-card">
                    <!-- Header de la card -->
                    <div class="card-header bg-white border-bottom py-2 px-3 d-flex justify-content-between align-items-center">
                        <span class="fw-bold text-primary small">@item.NumeroRequisicion</span>
                        <span class="badge bg-@item.EstadoClase">@item.EstadoTexto</span>
                    </div>
                    <div class="card-body p-3">
                        <!-- Empleado y fecha -->
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <div class="fw-semibold">@item.NombreEmpleadoRecibe</div>
                                <div class="text-muted small">@item.NumeroNominaEmpleado</div>
                            </div>
                            <div class="text-end text-muted small">
                                @item.FechaSolicitud.ToString("dd/MM/yy")
                            </div>
                        </div>
                        <!-- Info secundaria -->
                        <div class="d-flex gap-3 text-muted small mb-3">
                            <span><i class="bi bi-building me-1"></i>@item.NombreAlmacen</span>
                            <span><i class="bi bi-box-seam me-1"></i>@item.TotalMateriales mat.</span>
                        </div>
                        <!-- Solicitante -->
                        <div class="text-muted small mb-3">
                            <i class="bi bi-person-circle me-1"></i>Solicitó: @item.NombreUsuarioSolicita
                        </div>
                        <!-- Botones de acción -->
                        <div class="d-flex gap-2">
                            <a asp-action="Details" asp-route-id="@item.IdRequisicion"
                               class="btn btn-outline-info btn-sm flex-fill">
                                <i class="bi bi-eye me-1"></i>Ver
                            </a>
                            @if (puedeEditar && item.EstadoRequisicion == VH.Services.Entities.EstadoRequisicion.Pendiente && (esSuperAdmin || esAdmin))
                            {
                                <a asp-action="Aprobar" asp-route-id="@item.IdRequisicion"
                                   class="btn btn-outline-warning btn-sm flex-fill">
                                    <i class="bi bi-check-circle me-1"></i>Aprobar
                                </a>
                            }
                            @if (puedeEditar && item.EstadoRequisicion == VH.Services.Entities.EstadoRequisicion.Aprobada)
                            {
                                <a asp-action="Entregar" asp-route-id="@item.IdRequisicion"
                                   class="btn btn-outline-success btn-sm flex-fill">
                                    <i class="bi bi-box-arrow-right me-1"></i>Entregar
                                </a>
                            }
                            @if (item.EstadoRequisicion == VH.Services.Entities.EstadoRequisicion.Pendiente)
                            {
                                <form asp-action="Cancelar" asp-route-id="@item.IdRequisicion" method="post" class="flex-fill"
                                      onsubmit="return confirm('¿Cancelar esta requisición?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                                        <i class="bi bi-x-circle me-1"></i>Cancelar
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-inbox display-4 d-block mb-3"></i>
                <p class="mb-0">No hay requisiciones registradas</p>
            </div>
        }
    </div>

    <!-- ===================== VISTA ESCRITORIO: Tabla ===================== -->
    <div class="d-none d-md-block">
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4 py-3">N° Requisición</th>
                                <th>Solicitante</th>
                                <th>Empleado Receptor</th>
                                <th>Almacén</th>
                                <th class="text-center">Materiales</th>
                                <th class="text-center">Estado</th>
                                <th class="text-center pe-4">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <span class="fw-semibold text-primary">@item.NumeroRequisicion</span>
                                            <br />
                                            <small class="text-muted">@item.FechaSolicitud.ToString("dd/MM/yyyy HH:mm")</small>
                                        </td>
                                        <td>@item.NombreUsuarioSolicita</td>
                                        <td>
                                            <div>@item.NombreEmpleadoRecibe</div>
                                            <small class="text-muted">@item.NumeroNominaEmpleado</small>
                                        </td>
                                        <td>@item.NombreAlmacen</td>
                                        <td class="text-center">
                                            <span class="badge bg-secondary">@item.TotalMateriales</span>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge bg-@item.EstadoClase">@item.EstadoTexto</span>
                                        </td>
                                        <td class="text-center pe-4">
                                            <div class="btn-group btn-group-sm">
                                                <a asp-action="Details" asp-route-id="@item.IdRequisicion"
                                                   class="btn btn-outline-info" title="Ver detalles">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                @if (puedeEditar && item.EstadoRequisicion == VH.Services.Entities.EstadoRequisicion.Pendiente)
                                                {
                                                    <a asp-action="Aprobar" asp-route-id="@item.IdRequisicion"
                                                       class="btn btn-outline-warning" title="Aprobar/Rechazar">
                                                        <i class="bi bi-check-circle"></i>
                                                    </a>
                                                }
                                                @if (puedeEditar && item.EstadoRequisicion == VH.Services.Entities.EstadoRequisicion.Aprobada)
                                                {
                                                    <a asp-action="Entregar" asp-route-id="@item.IdRequisicion"
                                                       class="btn btn-outline-success" title="Entregar">
                                                        <i class="bi bi-box-arrow-right"></i>
                                                    </a>
                                                }
                                                @if (item.EstadoRequisicion == VH.Services.Entities.EstadoRequisicion.Pendiente)
                                                {
                                                    <form asp-action="Cancelar" asp-route-id="@item.IdRequisicion" method="post" class="d-inline"
                                                          onsubmit="return confirm('¿Está seguro de cancelar esta requisición?');">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="btn btn-outline-danger" title="Cancelar">
                                                            <i class="bi bi-x-circle"></i>
                                                        </button>
                                                    </form>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center py-5 text-muted">
                                        <i class="bi bi-inbox display-6 d-block mb-2"></i>
                                        No hay requisiciones registradas
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .filtros-scroll {
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
    }

        .filtros-scroll::-webkit-scrollbar {
            display: none;
        }

    .requisicion-card {
        border-radius: 12px;
        transition: box-shadow 0.2s;
    }

        .requisicion-card:active {
            box-shadow: 0 4px 15px rgba(0,0,0,0.1) !important;
        }

    /* Botones táctiles mínimo 44px */
    @@media (max-width: 767.98px) {
        .btn {
            min-height: 44px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .btn-sm {
            min-height: 40px;
        }
    }
</style>
